# matriz 2x2 entre proceso i y j
block <- cor_matrix(pca_list[[i]], pca_list[[j]])
# posiciones en la matriz grande
rows <- ((i-1)*2 + 1):(i*2)
cols <- ((j-1)*2 + 1):(j*2)
cor_big[rows, cols] <- block
}
}
