filter(!is.na(TX)) %>%
mutate(t = as.integer(DATE - min(DATE)) + 1)
Fourier <- data.frame()
for (i in unique(TEMP_daily$STAID)) {
yt <- ts(data = filter(TEMP_daily, STAID == i)$TX, frequency = 365)
xreg <- fourier(yt, K = 3)
Fourier <- rbind(Fourier, xreg)
}
TEMP_daily <- bind_cols(TEMP_daily, Fourier)
names(TEMP_daily) <- make.names(names(TEMP_daily))
lm.TEMP <- lm(TX ~ X + Y +
S1.365 + C1.365 + S2.365 + C2.365 + S3.365 + C3.365,
data = TEMP_daily)
kappa(model.matrix(lm.TEMP))
car::vif(lm.TEMP)
rm(lm.TEMP)
spObj <- SpatialPointsDataFrame(coords = TEMP_daily[, c("X", "Y")],
data = data.frame(STAID = TEMP_daily$STAID))
date <- as.Date(TEMP_daily$DATE)
STObj <- STIDF(sp = spObj,
time = date,
data = TEMP_daily %>%
transmute(TX = TX,
across(make.names(names(Fourier))),
HGHT = HGHT,
day = t))
splits <- c("Spatio-Temporal", "Temporal", "Spatial", "Random")
mtot <- length(STObj)
## Space-Time testing
STObj$time <- date
test_seq_st <- seq(as.Date("2025-12-24"), as.Date("2025-12-31"), by = "day")
valblock_st<- which(STObj$time %in% test_seq_st)
length(valblock_st)/mtot
## Temporal Testing
test_seq_time <- seq(as.Date("2025-06-01"), as.Date("2025-06-30"), by = "day")
valblock_time <- which(STObj$time %in% test_seq_time &
!(STObj$time  %in% test_seq_st))
length(valblock_time)/mtot
## Spatial Testing
STObj$station <- spObj$STAID
### Random stations
set.seed(1)
test_seq_space <- sample(unique(spObj@data$STAID),
size = 11, replace = FALSE)
valblock_space <- which(STObj$station %in% test_seq_space &
!(STObj$time %in% test_seq_time) &
!(STObj$time  %in% test_seq_st))
length(valblock_space) / mtot
## Missing at Random
obs_idx <- setdiff(1:mtot, c(valblock_st, valblock_time, valblock_space))
set.seed(321)
valrandom_idx <- sample(obs_idx,
0.0932 * mtot,
replace = FALSE) %>% sort()
length(valrandom_idx) / mtot
length(c(valblock_st, valblock_time, valblock_space, valrandom_idx)) / mtot
split <- data.frame(dim = c("ST", "Temporal", "Spatial", "Random"),
prop = c(length(valblock_st), length(valblock_time),
length(valblock_space), length(valrandom_idx)) / mtot)
sum(split$prop)
## Train
