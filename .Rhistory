obs_idx <- setdiff(1:mtot, valblock)
length(obs_idx) / mtot
STObj.obs <- STObj[obs_idx, ]
STObj.obs$X <- STObj.obs@sp@coords[,"X"]
STObj.obs$Y <- STObj.obs@sp@coords[,"Y"]
