library(dplyr)
TEMP <- read.csv("Italy_2025_Imp.csv", check.names = FALSE)
coords <- read.csv("Italy_2025_stations.csv", check.names = FALSE) %>%
mutate(STAID = as.character(STAID))
TEMP <- TEMP %>%
pivot_longer(!DATE, names_to = "STAID", values_to = "TX")
TEMP_daily <- TEMP %>%
mutate(DATE = as.Date(DATE, format = "%Y-%m-%d"),
STAID = as.character(STAID)) %>%
arrange(DATE, STAID) %>%
left_join(coords %>%
select(STAID, LON, LAT, X, Y, HGHT), by = "STAID") %>%
filter(!is.na(TX)) %>%
mutate(t = as.integer(DATE - min(DATE)) + 1)
TEMP_daily <- TEMP %>%
mutate(DATE = as.Date(DATE, format = "%Y-%m-%d"),
STAID = as.character(STAID)) %>%
arrange(DATE, STAID) %>%
left_join(coords %>%
dplyr::select(STAID, LON, LAT, X, Y, HGHT), by = "STAID") %>%
filter(!is.na(TX)) %>%
mutate(t = as.integer(DATE - min(DATE)) + 1)
Fourier <- data.frame()
for (i in unique(TEMP_daily$STAID)) {
yt <- ts(data = filter(TEMP_daily, STAID == i)$TX, frequency = 365)
xreg <- fourier(yt, K = 3)
Fourier <- rbind(Fourier, xreg)
}
TEMP_daily <- bind_cols(TEMP_daily, Fourier)
names(TEMP_daily) <- make.names(names(TEMP_daily))
lm.TEMP <- lm(TX ~ X + Y +
S1.365 + C1.365 + S2.365 + C2.365 + S3.365 + C3.365,
data = TEMP_daily)
kappa(model.matrix(lm.TEMP))
car::vif(lm.TEMP)
rm(lm.TEMP)
spObj <- SpatialPointsDataFrame(coords = TEMP_daily[, c("X", "Y")],
data = data.frame(STAID = TEMP_daily$STAID))
date <- as.Date(TEMP_daily$DATE)
STObj <- STIDF(sp = spObj,
time = date,
data = TEMP_daily %>%
transmute(TX = TX,
across(make.names(names(Fourier))),
HGHT = HGHT,
day = t))
splits <- c("Spatio-Temporal", "Temporal", "Spatial", "Random")
mtot <- length(STObj)
## Space-Time testing
STObj$time <- date
test_seq_st <- seq(as.Date("2025-12-24"), as.Date("2025-12-31"), by = "day")
valblock_st<- which(STObj$time %in% test_seq_st)
length(valblock_st)/mtot
## Temporal Testing
test_seq_time <- seq(as.Date("2025-06-01"), as.Date("2025-06-30"), by = "day")
valblock_time <- which(STObj$time %in% test_seq_time &
!(STObj$time  %in% test_seq_st))
length(valblock_time)/mtot
## Spatial Testing
STObj$station <- spObj$STAID
### Random stations
set.seed(1)
test_seq_space <- sample(unique(spObj@data$STAID),
size = 11, replace = FALSE)
valblock_space <- which(STObj$station %in% test_seq_space &
!(STObj$time %in% test_seq_time) &
!(STObj$time  %in% test_seq_st))
length(valblock_space) / mtot
## Missing at Random
obs_idx <- setdiff(1:mtot, c(valblock_st, valblock_time, valblock_space))
set.seed(321)
valrandom_idx <- sample(obs_idx,
0.0932 * mtot,
replace = FALSE) %>% sort()
length(valrandom_idx) / mtot
length(c(valblock_st, valblock_time, valblock_space, valrandom_idx)) / mtot
split <- data.frame(dim = c("ST", "Temporal", "Spatial", "Random"),
prop = c(length(valblock_st), length(valblock_time),
length(valblock_space), length(valrandom_idx)) / mtot)
sum(split$prop)
## Train
valblock <- c(valblock_st, valblock_time, valblock_space, valrandom_idx)
obs_idx <- setdiff(1:mtot, valblock)
length(obs_idx) / mtot
STObj.obs <- STObj[obs_idx, ]
STObj.obs$X <- STObj.obs@sp@coords[,"X"]
STObj.obs$Y <- STObj.obs@sp@coords[,"Y"]
STObj.val_st <- STObj[valblock_st, ]
STObj.val_st$X <- STObj.val_st@sp@coords[,"X"]
STObj.val_st$Y <- STObj.val_st@sp@coords[,"Y"]
STObj.val_time <- STObj[valblock_time, ]
STObj.val_time$X <- STObj.val_time@sp@coords[,"X"]
STObj.val_time$Y <- STObj.val_time@sp@coords[,"Y"]
STObj.val_space <- STObj[valblock_space, ]
STObj.val_space$X <- STObj.val_space@sp@coords[,"X"]
STObj.val_space$Y <- STObj.val_space@sp@coords[,"Y"]
STObj.val_random <- STObj[valrandom_idx, ]
STObj.val_random$X <- STObj.val_random@sp@coords[,"X"]
STObj.val_random$Y <- STObj.val_random@sp@coords[,"Y"]
## Dataframe
TEMP.train <- as.data.frame(STObj)
TEMP.train$TX[valblock] <- NA
TEMP.test <- as.data.frame(STObj)[valblock,]
STObj2.obs <- as(STObj.obs, "STFDF")
coords.train <- coords[coords$STAID %in% unique(STObj.obs@sp$STAID),]
coords.train <- unique(coords.train[, c("STAID", "X", "Y")])
maxdist <- max(dist(coords.train[,c("X", "Y")]))
cutoff <- 1/3*maxdist; width <- cutoff/15
formula.krige <- TX ~ S1.365 + C1.365 + S2.365 + C2.365 + S3.365 + C3.365
vv <- variogram(formula.krige,
data = STObj2.obs,
width = width,
cutoff = cutoff,
tlags = 0:7,
na.omit = TRUE,
assumeRegular = F)
View(sumetric_est)
gprods <- expand.grid(
sill_s   = c(0.5, 1.0, 1.5),
range_s  = c(40e3, 60e3, 80e3, 100e3),
nugget_s = c(0.01, 0.05, 0.10),
sill_t   = c(4.0, 4.5, 5.0),
range_t  = c(3, 4, 5, 6),
nugget_t = c(0.1, 0.2, 0.3),
k        = c(0.8, 1.2, 1.6, 2.0)
)
prodsum1 <- prodsum_est(vv, gprods, "Exp", "Gau")
sep_est <- function(variogram, grid, space_mod, time_mod){
n <- nrow(grid)
pb <- txtProgressBar(min = 0, max = n, style = 3)
on.exit(close(pb), add = TRUE)
out <- vector("list", nrow(grid))
for (i in seq_len(nrow(grid))) {
g <- grid[i, ]
mod0 <- vgmST("separable",
space = vgm(1, space_mod, g$range_s, nugget = g$nugget_s),
time  = vgm(1, time_mod, g$range_t, nugget = g$nugget_t),
sill  = g$sill)
fit <- try(fit.StVariogram(variogram, mod0, method = "L-BFGS-B",
lower = c(range.s = 1e3,
nugget.s = 0,
range.t = 0.001,
nugget.t = 0,
sill = 0.1),
upper = c(range.s = 4e6,
nugget.s = 10,
range.t = 20,
nugget.t = 2,
sill = 20),
control = list(
parscale = c(range.s = 2e4,
nugget.s = 0.10,
range.t = 5,
nugget.t = 0.10,
sill = 8))),
silent = TRUE)
if (!inherits(fit, "try-error")) {
out[[i]] <- list(
start = g,
MSE = attr(fit, "MSE"),
conv = attr(fit, "optim.output")$convergence,
par = attr(fit, "optim.output")$par,
fit = fit
)
}
setTxtProgressBar(pb, i)
}
res <- do.call(rbind, lapply(out, function(x) {
if (is.null(x)) return(NULL)
data.frame(start_range_s = x$start$range_s,
start_range_t = x$start$range_t,
MSE = x$MSE,
conv = x$conv,
par = paste(round(x$par, 4), collapse = ", "))
}))
res[order(res$MSE), ]
}
prodsum_est <- function(variogram, grid, space_mod, time_mod){
n <- nrow(grid)
pb <- txtProgressBar(min = 0, max = n, style = 3)
on.exit(close(pb), add = TRUE)
out <- vector("list", nrow(grid))
lower <- c(sill.s = 0.001,
range.s = 1e4,
nugget.s = 0,
sill.t = 0.001,
range.t = 0.1,
nugget.t = 0,
k = 0.001)
upper <- c(sill.s = 20,
range.s = 1.2e5,
nugget.s = 2,
sill.t = 20,
range.t = 20,
nugget.t = 2,
k = 100)
ctrl <- list(
maxit = 1000,
parscale = c(sill.s = 1,
range.s = 1e5,
nugget.s = 0.1,
sill.t = 1,
range.t = 1,
nugget.t = 0.1,
k = 1))
for (i in seq_len(nrow(grid))) {
g <- grid[i, ]
mod0 <- vgmST("productSum",
space = vgm(g$sill_s, space_mod, g$range_s, nugget = g$nugget_s),
time  = vgm(g$sill_t, time_mod, g$range_t, nugget = g$nugget_t),
k = g$k)
fit <- try(fit.StVariogram(vv, mod0, method = "L-BFGS-B",
lower = lower,
upper = upper,
control = ctrl), silent = TRUE)
if (!inherits(fit, "try-error")) {
out[[i]] <- list(
start = g,
MSE = attr(fit, "MSE"),
conv = attr(fit, "optim.output")$convergence,
par = extractPar(fit),
fit = fit
)
}
setTxtProgressBar(pb, i)
}
res <- do.call(rbind, lapply(out, function(x) {
if (is.null(x)) return(NULL)
data.frame(start_range_s = x$start$range_s,
start_range_t = x$start$range_t,
MSE = x$MSE,
conv = x$conv,
par = paste(round(x$par, 4), collapse = ", "))
}))
res[order(res$MSE), ]
}
prodsum1 <- prodsum_est(vv, gprods, "Exp", "Gau")
