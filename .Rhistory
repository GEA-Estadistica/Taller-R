STObj.val_st$Y <- STObj.val_st@sp@coords[,"Y"]
STObj.val_time <- STObj[valblock_time, ]
STObj.val_time$X <- STObj.val_time@sp@coords[,"X"]
STObj.val_time$Y <- STObj.val_time@sp@coords[,"Y"]
STObj.val_space <- STObj[valblock_space, ]
STObj.val_space$X <- STObj.val_space@sp@coords[,"X"]
STObj.val_space$Y <- STObj.val_space@sp@coords[,"Y"]
